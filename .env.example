# Server-only FAL credential. Never expose this value to browser code.
FAL_API_KEY=

# Optional Apply Style overrides. These defaults use Kling O3 Edit Standard
# for video, Nano Banana 2 Edit for images, and fal's trim utility.
PRISMFLOW_STYLE_VIDEO_MODEL=fal-ai/kling-video/o3/standard/video-to-video/edit
PRISMFLOW_STYLE_IMAGE_MODEL=fal-ai/nano-banana-2/edit
PRISMFLOW_STYLE_TRIM_MODEL=fal-ai/workflow-utilities/trim-video

# Gemini model routed through FAL OpenRouter for per-beat screenplay blocks.
PRISMFLOW_STORYBOARD_SCRIPT_MODEL=google/gemini-2.5-flash

# Background score generation. The music model renders the score audio
# (ElevenLabs Music supports sectioned composition plans; sonilo/v1.1/video-to-music
# and fal-ai/lyria3/pro also work). The direction model writes the cue sheet.
PRISMFLOW_MUSIC_MODEL=fal-ai/elevenlabs/music
PRISMFLOW_SCORE_DIRECTION_MODEL=google/gemini-2.5-flash

# OpenAI-compatible LLM endpoint for the timeline editing agent (server-only).
# Example: http://localhost:11434/v1 (Ollama) or https://openrouter.ai/api/v1
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
