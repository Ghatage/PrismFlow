{
	"repository": {
		"url": "https://github.com/remotion-dev/remotion/tree/main/packages/browser-studio"
	},
	"name": "@remotion/browser-studio",
	"private": true,
	"version": "4.0.490",
	"description": "Run Remotion Studio in the browser",
	"main": "dist/esm/index.mjs",
	"types": "dist/index.d.ts",
	"module": "dist/esm/index.mjs",
	"type": "module",
	"scripts": {
		"dev": "bun src/dev/server.ts",
		"test": "bun test src/test",
		"formatting": "oxfmt src --check",
		"format": "oxfmt src",
		"lint": "eslint src",
		"watch": "tsgo -w",
		"make": "tsgo && bun --env-file=../.env.bundle bundle.ts"
	},
	"author": "Jonny Burger <jonny@remotion.dev>",
	"contributors": [],
	"license": "Remotion License",
	"bugs": {
		"url": "https://github.com/remotion-dev/remotion/issues"
	},
	"dependencies": {
		"@remotion/studio-shared": "4.0.490",
		"@rspack/browser": "2.1.1"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"module": "./dist/esm/index.mjs",
			"import": "./dist/esm/index.mjs"
		},
		"./browser-studio-worker": {
			"types": "./dist/browser-studio-worker.d.ts",
			"module": "./dist/esm/browser-studio-worker.mjs",
			"import": "./dist/esm/browser-studio-worker.mjs"
		},
		"./package.json": "./package.json"
	},
	"devDependencies": {
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"@typescript/native-preview": "7.0.0-dev.20260217.1",
		"eslint": "9.19.0",
		"react": "19.2.3",
		"react-dom": "19.2.3"
	},
	"keywords": [
		"remotion",
		"studio",
		"rspack",
		"browser"
	]
}
